conky.config = {
    alignment = 'top_right',
    background = true,
    border_width = 1,
    cpu_avg_samples = 2,
    double_buffer = true,
    font = 'Inter:size=10',
    gap_x = 18,
    gap_y = 18,
    minimum_height = 180,
    minimum_width = 280,
    own_window = true,
    own_window_type = 'desktop',
    own_window_transparent = true,
    own_window_argb_visual = true,
    own_window_argb_value = 220,
    update_interval = 20,
};

conky.text = [[
${color #2563EB}${font Inter:size=12:bold}VEKTRA AI METER${font}${color}
${color #94a3b8}Grok · Codex · Claude${color}
${hr 1 #2563EB}
${execpi 20 python3 -c "import json, pathlib; p=pathlib.Path.home()/'.local/share/vektra-ai-meter/snapshot.json';\nimport subprocess, os;\nroot=os.path.expanduser('~/.local/bin/ai-meter');\n(subprocess.run([root,'snapshot','--write'], check=False) if not p.exists() else None);\ndata=json.loads(p.read_text()) if p.exists() else {'summary':{},'providers':[]};\ns=data.get('summary',{});\nprint(f\"Total {s.get('total_tokens_fmt','—')}  Today {s.get('today_tokens_fmt','—')}  Active {s.get('active_sessions',0)}\")"}
${hr 1 #1e293b}
${execpi 20 python3 -c "import json, pathlib; p=pathlib.Path.home()/'.local/share/vektra-ai-meter/snapshot.json';\ndata=json.loads(p.read_text()) if p.exists() else {'providers':[]};\nlines=[];\n[lines.append(f\"{x.get('label','?'):<12} {str(x.get('total_tokens',0)):>8}  {x.get('model') or ''}\") for x in data.get('providers',[])];\nprint('\\n'.join(lines) or 'No providers detected')"}
]];